@{
    ViewData["Title"] = "Home Page";
}

<div>
        <h1>Grupo de M y L</h1>
          <img src="/images/logo.jpg" />
</div>
<div style="text-align:center;">

@foreach(Integrante integrante in ViewBag.Integrantes.Values)
{
    <div style="display:inline-block; margin:20px; text-align:center; border: 1px solid black; background-color: lightgray;padding:15px;">
        <h5>Integrante</h5>
        <img src="@integrante.GetFoto()" width="120", height="120" />

        <h3>@integrante.GetNombre()</h3>

        <a href="@Url.Action("SelectIntegrante", "Home", new { dni = integrante.GetDNI() })">
            Ver info
        </a>

    </div>
}

</div>
